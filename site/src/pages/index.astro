          <div class="card-label">
            <span class="en-text">{u.labelEn}</span>
            <span class="es-text">{u.labelEs}</span>
          </div>
          <div class="card-dims-area">
            <span class="card-dims-badge">{u.dims}</span>
            <span class="card-area-badge">{u.area}</span>
          </div>
          <div class="card-regular-price">${u.regularPrice}/mo</div>
          <div class="card-price">${u.price}</div>
          <div class="card-mo">
            <span class="en-text">/month</span>
            <span class="es-text">/mes</span>
          </div>
          <div class="card-promo-label">
            <span class="en-text">PROMO PRICE</span>
            <span class="es-text">PRECIO PROMOCIÓN</span>
          </div>
          <div class="card-desc">
            <span class="en-text">{u.descEn}</span>
            <span class="es-text">{u.descEs}</span>
          </div>
          <a href={`https://wa.me/50684227985?text=${waMsg}`}
             target="_blank" rel="noopener"
             class="card-cta en-text"
             style={u.popular ? 'background:var(--gold);color:var(--green)' : 'background:var(--green);color:var(--offwhite)'}>
            Ask on WhatsApp
          </a>
          <a href={`https://wa.me/50684227985?text=${waMsgEs}`}
             target="_blank" rel="noopener"
             class="card-cta es-text"
             style={u.popular ? 'background:var(--gold);color:var(--green)' : 'background:var(--green);color:var(--offwhite)'}>
            Preguntar por WhatsApp
          </a>

          {/* Alert me when available */}
          <button class="alert-toggle">
            <span class="en-text">🔔 Alert me when available</span>
            <span class="es-text">🔔 Avísame cuando esté disponible</span>
          </button>
          <div class="alert-form">
            <form class="alert-unit-form">
              <input type="hidden" name="form_type" value="unit_alert" />
              <input type="hidden" name="unit_type" value={u.type} />
              <input type="hidden" name="unit_price" value={`$${u.price}/mo`} />
              <input class="lg-field" type="tel" name="whatsapp"
                autocomplete="tel"
                placeholder="WhatsApp" required />
              <select class="lg-field" name="unit_preference" required>
                <option value="">Size / Tamaño: A B C D E</option>
                <option value="A">A — 1.5×1.5 m · $50/mo</option>
                <option value="B">B — 2×2 m · $80/mo</option>
                <option value="C">C — 4×2.25 m · $200/mo</option>
                <option value="D">D — 4×4.5 m · $180/mo</option>
                <option value="E">E — 6×6 m · $360/mo</option>
              </select>
              <label class="lg-check">
                <input type="checkbox" name="consent" required />
                <span>
                  <span class="en-text">I agree to receive storage updates. No spam.</span>
                  <span class="es-text">Acepto recibir actualizaciones de almacenaje.</span>
                </span>
              </label>
              <button type="submit" class="lg-btn">
                <span class="en-text">Notify Me</span>
                <span class="es-text">Notifícame</span>
              </button>
            </form>
            <div class="alert-thanks">
              <span class="en-text">✅ We'll notify you when it's available!</span>
              <span class="es-text">✅ ¡Te avisaremos cuando esté disponible!</span>
            </div>
          </div>

        </div>
      );
    })}
  </div>
