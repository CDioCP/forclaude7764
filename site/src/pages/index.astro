  <!-- Schema: SelfStorage + LocalBusiness -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["SelfStorage", "LocalBusiness"],
    "name": "AA Self Storage MiniBodegas",
    "url": "https://aastorage.cr",
    "telephone": "+506-4000-0854",
    "priceRange": "$50-$360",
    "currenciesAccepted": "USD",
    "openingHours": "Mo-Fr 08:00-17:00",
    "description": "Secure self storage units in La Uruca, San José. CCTV. Month-to-month. English-speaking staff.",
    "hasMap": "https://maps.google.com/?q=AA+Self+Storage+La+Uruca+San+Jose",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "La Uruca, junto a Migración y Extranjería",
      "addressLocality": "San José",
      "addressCountry": "CR"
    }
  }
  </script>

  <style>
    :root {
      --green:     #1B4D3E;
      --green-dk:  #0f2d23;
      --green-lg:  #2a6b56;
      --gold:      #C9A84C;
      --gold-lt:   #e2c47a;
      --offwhite:  #F9F7F4;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--offwhite);
      color: var(--green);
      margin: 0;
    }

    h1, h2, h3 { font-family: 'Playfair Display', serif; }

    /* ── Language toggle ───────────────────────────── */
    html.lang-en .es-text { display: none !important; }
    html.lang-es .en-text { display: none !important; }

    /* ── Nav ───────────────────────────────────────── */
    .nav-wrap {
      background: var(--green);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }
    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      flex-shrink: 0;
    }
    .nav-logo-icon {
      width: 38px;
      height: 38px;
      background: var(--gold);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .nav-logo-text {
      font-family: 'Playfair Display', serif;
      font-weight: 800;
      color: var(--offwhite);
      font-size: 1rem;
      line-height: 1.15;
    }
    .nav-logo-sub {
      font-size: 0.6rem;
      font-weight: 600;
      font-family: 'Nunito', sans-serif;
      color: var(--gold);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .nav-phone {
      color: var(--gold);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      flex: 1;
      justify-content: center;
    }
    .nav-link {
      color: rgba(249,247,244,0.8);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.02em;
      transition: color 0.15s;
    }
    .nav-link:hover { color: var(--gold); }
    @media (max-width: 639px) { .nav-links { display: none; } }
    .lang-toggle {
      display: flex;
      align-items: center;
      background: rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 3px;
      gap: 2px;
    }
    .lang-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px 9px;
      border-radius: 16px;
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      font-size: 0.72rem;
      color: rgba(249,247,244,0.8);
      transition: background 0.15s, color 0.15s;
    }
    .lang-btn.active {
      background: rgba(201,168,76,0.35);
      color: var(--offwhite);
    }

    /* ── Hero (photo bg + lead card) ───────────────── */
    .hero {
      position: relative;
      display: flex;
      align-items: center;
      min-height: clamp(420px, 64vh, 660px);
      overflow: hidden;
      background: var(--green-dk);
    }
    .hero-photo {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      display: block;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: rgba(27, 77, 62, 0.35);
    }
    .hero-inner {
      position: relative; z-index: 2;
      max-width: 1100px; margin: 0 auto;
      padding: 3.5rem 1.5rem;
      width: 100%;
    }
    .hero-card {
      max-width: 520px;
      background: rgba(10, 32, 24, 0.55);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(201, 168, 76, 0.25);
      border-radius: 18px;
      padding: 2.5rem 2.25rem 2.25rem;
    }
    .hero-card h1 {
      color: var(--offwhite);
      font-size: clamp(1.8rem, 4.2vw, 3rem);
      font-weight: 900;
      margin: 0 0 0.55rem;
      line-height: 1.1;
    }
    .hero-finally {
      display: block;
      font-style: italic;
      color: var(--gold);
      font-size: 1.15em;
      margin-bottom: 0.05em;
      letter-spacing: -0.01em;
    }
    .hero-sub {
      color: rgba(249, 247, 244, 0.82);
      font-size: clamp(0.88rem, 1.8vw, 1rem);
      margin: 0 0 1.8rem;
      line-height: 1.65;
    }
    .hero-cta-row {
      display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;
    }
    .hero-btn-wa {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.85rem 1.6rem;
      background: #25D366; color: white;
      border-radius: 10px; text-decoration: none;
      font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 0.9rem;
      box-shadow: 0 4px 18px rgba(37, 211, 102, 0.35);
      transition: opacity 0.2s, transform 0.15s;
    }
    .hero-btn-wa:hover { opacity: 0.88; transform: translateY(-2px); }
    .hero-btn-guide {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.85rem 1.6rem;
      background: var(--gold); color: var(--green);
      border: none; border-radius: 10px; cursor: pointer;
      font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 0.9rem;
      box-shadow: 0 4px 18px rgba(201, 168, 76, 0.35);
      transition: opacity 0.2s, transform 0.15s;
    }
    .hero-btn-guide:hover { opacity: 0.88; transform: translateY(-2px); }

    /* Mobile: carousel behind card */
    @media (max-width: 767px) {
      .hero {
        min-height: clamp(480px, 85vh, 680px);
        overflow: hidden;
        align-items: flex-end;
      }
      .hero-photo {
        position: absolute; inset: 0;
        width: 100%; height: 100%;
        object-fit: cover; object-position: center 20%;
      }
      .hero-overlay { display: block; background: rgba(10,32,24,0.45); }
      .hero-inner {
        position: relative; z-index: 2;
        padding: 1.5rem 1rem 2rem;
      }
      .hero-card {
        max-width: 100%;
        background: rgba(10, 32, 24, 0.72);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: 1.75rem 1.25rem 2rem;
      }
      .hero-card h1 { font-size: clamp(1.6rem, 7vw, 2.2rem); }
    }
    @media (max-width: 480px) {
      .hero-cta-row { flex-direction: column; align-items: stretch; }
      .hero-btn-wa, .hero-btn-guide { justify-content: center; }
    }

    /* ── Photo Carousel ─────────────────────────────── */
    .photo-carousel {
      position: relative;
      height: clamp(300px, 52vh, 580px);
      overflow: hidden;
      background: var(--green-dk);
    }
    .pc-slide {
      position: absolute; inset: 0;
      opacity: 0; pointer-events: none;
    }
    .pc-slide.active { opacity: 1; pointer-events: auto; }
    .pc-bg {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center;
      will-change: transform;
    }
    @keyframes kenburns {
      from { transform: scale(1) translate(0, 0); }
      to   { transform: scale(1.08) translate(-1%, -0.5%); }
    }
    @keyframes kenburnsBig {
      from { transform: scale(1.08) translate(0, 0); }
      to   { transform: scale(1.17) translate(-1%, -0.5%); }
    }
    .pc-bg.kb { animation: kenburns 5s ease-in-out forwards; }

    /* Low-res slides: blur + bigger scale so edges never show */
    .pc-slide[data-blur] .pc-bg {
      filter: blur(2px);
      transform: scale(1.08);
    }
    .pc-slide[data-blur] .pc-bg.kb { animation-name: kenburnsBig; }
    .pc-slide[data-blur] .pc-overlay { background: rgba(27, 77, 62, 0.55); }

    /* Solid design slide */
    .pc-solid { background: var(--green-dk); }
    .pc-solid-headline {
      font-size: clamp(2rem, 5vw, 3.4rem);
      color: var(--gold);
      text-shadow: none;
      letter-spacing: -0.02em;
    }
    .pc-solid-headline::after {
      content: '';
      display: block;
      width: 3rem; height: 3px;
      background: var(--gold);
      margin: 0.6rem auto 0;
      border-radius: 2px;
    }

    /* Tagline slide — centered image, no stretch */
    .pc-tagline { background: var(--green-dk); }
    .pc-tagline-img {
      max-width: 800px;
      width: 100%;
      height: auto;
      display: block;
      margin: 0 auto;
      object-fit: contain;
    }
    @media (max-width: 640px) {
      .pc-tagline-img { max-width: 95vw; }
    }

    .pc-overlay {
      position: absolute; inset: 0;
      background: rgba(15,45,35,0.45);
    }
    .pc-slide.no-overlay .pc-overlay { display: none; }
    .pc-text {
      position: absolute; inset: 0; z-index: 2;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center; padding: 1.5rem 2rem;
    }
    .pc-headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.4rem, 3.5vw, 2.4rem);
      font-weight: 900; color: var(--offwhite);
      text-shadow: 0 2px 14px rgba(0,0,0,0.55);
      margin: 0 0 0.5rem; line-height: 1.2;
      max-width: 700px;
    }
    .pc-sub {
      color: rgba(249,247,244,0.82);
      font-size: clamp(0.8rem, 2vw, 1rem);
      margin: 0 0 1.5rem;
      text-shadow: 0 1px 6px rgba(0,0,0,0.45);
      max-width: 560px;
    }
    .pc-cta {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.75rem 1.6rem;
      background: #25D366; color: white;
      border: none; border-radius: 10px;
      font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 0.92rem;
      cursor: pointer; text-decoration: none;
      box-shadow: 0 4px 16px rgba(0,0,0,0.3);
      transition: transform 0.15s;
    }
    .pc-cta:hover { transform: translateY(-2px); }
    /* Arrows */
    .pc-arrow {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 50%; width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: white; z-index: 10;
      transition: background 0.2s;
    }
    .pc-arrow:hover { background: rgba(255,255,255,0.24); }
    .pc-arrow-prev { left: 1rem; }
    .pc-arrow-next { right: 1rem; }
    /* Dots */
    .pc-dots {
      position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%);
      display: flex; gap: 0.45rem; z-index: 10;
    }
    .pc-dot {
      width: 9px; height: 9px; border-radius: 50%;
      background: rgba(255,255,255,0.35);
      border: none; cursor: pointer; padding: 0;
      transition: background 0.2s, transform 0.2s;
    }
    .pc-dot.active { background: var(--gold); transform: scale(1.4); }
    @media (max-width: 640px) {
      .pc-arrow { width: 36px; height: 36px; }
      .pc-sub { display: none; }
    }

    /* ── Trust strip ───────────────────────────────── */
    .trust-strip {
      background: var(--green);
      border-top: 1px solid rgba(201,168,76,0.2);
    }
    .trust-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1rem 1rem;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem 2.5rem;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: rgba(249,247,244,0.9);
      font-size: 0.85rem;
      font-weight: 700;
    }

    /* ── Pricing section ────────────────────────────── */
    .units-section {
      background: var(--green);
      padding: 4.5rem 1.5rem;
    }
    .units-inner {
      max-width: 1160px;
      margin: 0 auto;
    }
    .section-heading {
      text-align: center;
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      color: var(--offwhite);
      margin: 0 0 0.4rem;
    }
    .section-sub {
      text-align: center;
      color: rgba(249,247,244,0.65);
      font-size: 0.9rem;
      margin: 0 0 3rem;
    }
    .units-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.25rem;
    }
    .unit-card {
      background: white;
      border-radius: 16px;
      padding: 1.75rem 1.25rem 1.5rem;
      border: 3px solid transparent;
      position: relative;
      overflow: hidden;
      text-align: center;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .unit-card:hover {
      border-color: var(--gold);
      transform: translateY(-5px);
      box-shadow: 0 12px 36px rgba(0,0,0,0.18);
    }
    .unit-card.popular { border-color: var(--gold); }
    .popular-badge {
      position: absolute; top: 0; right: 0;
      background: var(--gold); color: var(--green);
      font-size: 0.62rem; font-weight: 800;
      padding: 5px 12px;
      border-radius: 0 13px 0 10px;
      letter-spacing: 0.07em;
    }
    .card-letter {
      width: 54px; height: 54px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1.55rem; font-weight: 900;
      margin: 0 auto 0.6rem;
    }
    .card-label {
      font-size: 0.75rem; font-weight: 700;
      color: #aaa; text-transform: uppercase;
      letter-spacing: 0.06em; margin-bottom: 0.85rem;
    }
    .card-dims-area {
      display: flex; justify-content: center;
      gap: 0.4rem; margin-bottom: 1.25rem; flex-wrap: wrap;
    }
    .card-dims-badge {
      font-size: 0.82rem; font-weight: 700;
      padding: 4px 10px; border-radius: 20px;
      background: rgba(27,77,62,0.1); color: var(--green);
    }
    .card-area-badge {
      font-size: 0.82rem; font-weight: 700;
      padding: 4px 10px; border-radius: 20px;
      background: rgba(201,168,76,0.15); color: #8a6a1a;
    }
    .card-regular-price {
      font-size: 0.88rem; color: #ccc;
      text-decoration: line-through; margin-bottom: 0.15rem;
    }
    .card-price {
      font-family: 'Playfair Display', serif;
      font-size: 2.6rem; font-weight: 900;
      color: var(--green); line-height: 1;
    }
    .card-mo { color: #999; font-size: 0.8rem; margin-bottom: 0.4rem; }
    .card-promo-label {
      display: inline-block;
      background: #e8f5e9; color: #2e7d32;
      font-size: 0.65rem; font-weight: 800;
      padding: 3px 9px; border-radius: 20px;
      margin-bottom: 1rem; letter-spacing: 0.05em;
    }
    .card-desc { color: #666; font-size: 0.82rem; margin-bottom: 1.25rem; min-height: 2.2rem; line-height: 1.5; }
    .card-cta {
      display: block; text-align: center;
      padding: 0.7rem 0; border-radius: 10px;
      text-decoration: none; font-weight: 800; font-size: 0.88rem;
      transition: opacity 0.2s;
    }
    .card-cta:hover { opacity: 0.85; }

    /* ── About section ─────────────────────────────── */
    .about-section {
      background: var(--offwhite);
      padding: 4rem 1.5rem;
    }
    .about-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-top: 2.5rem;
    }
    .about-card {
      background: white;
      border-radius: 14px;
      padding: 1.75rem 1.5rem;
      border: 1px solid rgba(27,77,62,0.1);
      box-shadow: 0 2px 12px rgba(27,77,62,0.06);
    }
    .about-icon {
      margin-bottom: 1rem;
    }
    .about-card h3 {
      color: var(--green);
      font-size: 1rem;
      font-weight: 800;
      margin: 0 0 0.5rem;
    }
    .about-card p {
      color: #444;
      font-size: 0.88rem;
      line-height: 1.65;
      margin: 0;
    }
    .about-section .section-heading { color: var(--green); }
    .about-section .section-sub { color: #555; }

    /* ── Location section ──────────────────────────── */
    .location-section {
      background: var(--green);
      padding: 4rem 1rem;
      text-align: center;
    }
    .location-h2 {
      color: var(--offwhite);
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      margin: 0 0 0.4rem;
    }
    .location-addr {
      color: rgba(249,247,244,0.65);
      font-size: 0.9rem;
      margin: 0 0 0.2rem;
    }
    .location-hours {
      color: rgba(249,247,244,0.45);
      font-size: 0.8rem;
      margin: 0 0 2.25rem;
    }
    .location-btns {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.85rem;
    }
    .loc-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.8rem 1.6rem;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 800;
      font-size: 0.9rem;
      transition: opacity 0.2s, transform 0.15s;
    }
    .loc-btn:hover { opacity: 0.88; transform: translateY(-1px); }

    /* ── Contact section ──────────────────────────── */
    .contact-section {
      background: var(--offwhite);
      padding: 4.5rem 1.5rem;
      text-align: center;
    }
    .contact-inner { max-width: 600px; margin: 0 auto; }
    .contact-section .section-heading { color: var(--green); }
    .contact-section .section-sub { color: #555; }
    .contact-btns {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin-top: 2.5rem;
    }
    .contact-btn-wa, .contact-btn-call {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 1rem 2rem;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 800;
      font-size: 1.05rem;
      transition: opacity 0.2s, transform 0.15s;
    }
    .contact-btn-wa { background: #25D366; color: white; }
    .contact-btn-call { background: var(--green); color: var(--offwhite); }
    .contact-btn-wa:hover, .contact-btn-call:hover { opacity: 0.88; transform: translateY(-2px); }
    .contact-note { margin-top: 1.75rem; color: #888; font-size: 0.85rem; }

    /* ── Footer ────────────────────────────────────── */
    footer {
      background: var(--green-dk);
      padding: 2.25rem 1rem;
      text-align: center;
    }
    .footer-logo {
      height: 32px;
      width: auto;
      display: block;
      margin: 0 auto 0.9rem;
      filter: brightness(0) invert(1);
      opacity: 0.75;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }
    .footer-line {
      color: rgba(249,247,244,0.55);
      font-size: 0.82rem;
      margin: 0 0 0.2rem;
    }
    .footer-line a { color: var(--gold); text-decoration: none; }
    .footer-hours {
      color: rgba(249,247,244,0.35);
      font-size: 0.75rem;
      margin-top: 1.2rem;
    }

    /* ── WhatsApp float ────────────────────────────── */
    .wa-float {
      position: fixed;
      bottom: 22px;
      right: 22px;
      width: 58px;
      height: 58px;
      background: #25D366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 18px rgba(37,211,102,0.45);
      z-index: 999;
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
    }
    .wa-float:hover {
      transform: scale(1.1);
      box-shadow: 0 6px 28px rgba(37,211,102,0.55);
    }

    /* ── Responsive tweaks ─────────────────────────── */
    @media (max-width: 640px) {
      .nav-phone { display: none; }
      .units-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 400px) {
      .units-grid { grid-template-columns: 1fr; }
    }

    /* ══════════════ LEAD GEN ══════════════ */

    /* Overlay backdrop */
    .lg-overlay {
      position: fixed; inset: 0;
      background: rgba(15,45,35,0.78);
      z-index: 1000;
      display: flex; align-items: center; justify-content: center;
      padding: 1rem;
      opacity: 0; pointer-events: none;
      transition: opacity 0.28s;
    }
    .lg-overlay.open { opacity: 1; pointer-events: auto; }

    /* Modal box */
    .lg-box {
      background: white;
      border-radius: 16px;
      max-width: 420px; width: 100%;
      padding: 2rem 1.75rem 1.75rem;
      position: relative;
      box-shadow: 0 20px 60px rgba(0,0,0,0.38);
      max-height: 92vh; overflow-y: auto;
    }
    @media (max-width: 380px) {
      .lg-box { padding: 1.5rem 1.2rem 1.2rem; }
    }

    /* Close × */
    .lg-close {
      position: absolute; top: 0.8rem; right: 1rem;
      background: none; border: none; cursor: pointer;
      color: #ccc; font-size: 1.7rem; line-height: 1; padding: 0;
      transition: color 0.15s;
    }
    .lg-close:hover { color: var(--green); }

    /* Copy */
    .lg-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.28rem; font-weight: 800;
      color: var(--green); margin: 0 0 0.35rem; line-height: 1.25;
    }
    .lg-sub { color: #777; font-size: 0.85rem; margin: 0 0 1.2rem; line-height: 1.45; }

    /* Inputs */
    .lg-field {
      width: 100%; padding: 0.7rem 0.9rem;
      border: 1.5px solid #e0e0e0; border-radius: 8px;
      font-family: 'Nunito', sans-serif; font-size: 0.9rem;
      color: var(--green); margin-bottom: 0.6rem;
      outline: none; transition: border-color 0.2s; display: block;
      background: white;
    }
    .lg-field:focus { border-color: var(--gold); }
    select.lg-field { cursor: pointer; }

    /* Checkbox row */
    .lg-check {
      display: flex; align-items: flex-start; gap: 0.5rem;
      margin-bottom: 1rem; font-size: 0.8rem; color: #555; cursor: pointer;
    }
    .lg-check input[type="checkbox"] {
      margin-top: 2px; flex-shrink: 0; accent-color: var(--green);
    }

    /* Submit button */
    .lg-btn {
      width: 100%; padding: 0.85rem;
      background: var(--gold); color: var(--green);
      border: none; border-radius: 10px;
      font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 0.95rem;
      cursor: pointer; transition: opacity 0.2s;
    }
    .lg-btn:hover { opacity: 0.88; }
    .lg-btn:disabled { opacity: 0.55; cursor: default; }

    /* Note below button */
    .lg-note { text-align: center; color: #aaa; font-size: 0.75rem; margin: 0.55rem 0 0; }
    .lg-field-error { color: #e05252; font-size: 0.75rem; margin: -6px 0 6px 2px; min-height: 0; display: none; }
    .lg-field-error.visible { display: block; }
    .lg-field.invalid { border-color: #e05252; }

    /* Thank-you state */
    .lg-thanks { text-align: center; padding: 0.5rem 0; }
    .lg-thanks-icon { font-size: 2.5rem; margin-bottom: 0.4rem; }
    .lg-thanks h3 {
      font-family: 'Playfair Display', serif;
      color: var(--green); margin: 0 0 0.45rem;
    }
    .lg-thanks p { color: #666; font-size: 0.88rem; margin: 0; line-height: 1.5; }

    /* ── Sticky Mobile Bar ─────────────────── */
    .sticky-bar {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0;
      background: var(--green-dk);
      border-top: 2px solid var(--gold);
      z-index: 990;
    }
    @media (max-width: 639px) {
      body { padding-bottom: 58px; }
      .sticky-bar { display: flex; }
      .sticky-bar.hidden { display: none !important; }
      .wa-float { display: none; }
    }
    .sb-btn {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 0.55rem 0.2rem;
      border: none; background: none; cursor: pointer;
      border-right: 1px solid rgba(201,168,76,0.18);
      font-family: 'Nunito', sans-serif; text-decoration: none;
      -webkit-tap-highlight-color: transparent;
    }
    .sb-btn:last-child { border-right: none; }
    .sb-val { color: var(--gold); font-weight: 800; font-size: 0.78rem; line-height: 1.2; }
    .sb-lbl {
      color: rgba(249,247,244,0.7); font-size: 0.58rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em; margin-top: 1px;
    }

    /* ── Unit Card Alert Form ──────────────── */
    .alert-toggle {
      display: block; width: 100%; text-align: center;
      margin-top: 0.6rem; font-size: 0.78rem;
      color: var(--green-lg); font-weight: 700;
      background: none; border: none; cursor: pointer;
      text-decoration: underline; text-underline-offset: 3px;
      font-family: 'Nunito', sans-serif; transition: color 0.15s;
    }
    .alert-toggle:hover { color: var(--green); }
    .alert-form {
      display: none; margin-top: 0.65rem;
      background: var(--offwhite); border-radius: 8px;
      padding: 0.85rem 0.75rem 0.75rem;
      border: 1px solid rgba(27,77,62,0.12);
    }
    .alert-form.open { display: block; }
    .alert-form .lg-field {
      margin-bottom: 0.45rem; font-size: 0.82rem; padding: 0.6rem 0.75rem;
    }
    .alert-form .lg-check { font-size: 0.75rem; margin-bottom: 0.75rem; }
    .alert-form .lg-btn { font-size: 0.82rem; padding: 0.6rem; }
    .alert-thanks {
      display: none; text-align: center; padding: 0.5rem 0;
      color: var(--green); font-weight: 800; font-size: 0.82rem;
    }
  </style>

</head>

