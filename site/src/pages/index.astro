  </p>

  <div class="units-grid">
    {units.map((u) => {
      const waMsg = encodeURIComponent(`Hello! I'm interested in Unit Type ${u.type} (${u.dims} = ${u.area}) at $${u.price}/mo. Is it available?`);
      const waMsgEs = encodeURIComponent(`¡Hola! Me interesa la Unidad Tipo ${u.type} (${u.dims} = ${u.area}) a $${u.price}/mes. ¿Está disponible?`);
      return (
        <div class={`unit-card${u.popular ? ' popular' : ''}`}>
          {u.popular && (
            <div class="popular-badge">
              <span class="en-text">POPULAR</span>
              <span class="es-text">POPULAR</span>
            </div>
          )}
          <div class="card-letter" style={u.popular ? 'background:var(--gold);color:var(--green)' : 'background:var(--green);color:var(--gold)'}>
            {u.type}
