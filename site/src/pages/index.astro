---
import '../styles/global.css';

const units = [
  { type: 'A', dims: '1.5 × 1.5 m', area: '2.25 m²', regularPrice: 56.25, price: 50,  labelEn: 'Starter',      labelEs: 'Básica',    descEn: 'Boxes, clothes, small personal items',         descEs: 'Cajas, ropa, artículos personales pequeños' },
  { type: 'B', dims: '2 × 2 m',     area: '4 m²',     regularPrice: 100,   price: 80,  labelEn: 'Home',         labelEs: 'Hogar',     descEn: 'Furniture, appliances, seasonal gear',         descEs: 'Muebles, electrodomésticos, artículos de temporada' },
  { type: 'C', dims: '4 × 2.25 m',  area: '10 m²',    regularPrice: 250,   price: 200, labelEn: 'Business',     labelEs: 'Negocio',   descEn: 'Inventory, equipment, office overflow',        descEs: 'Inventario, equipo, desbordamiento de oficina', popular: true },
  { type: 'D', dims: '4 × 4.5 m',   area: '18 m²',    regularPrice: 216,   price: 180, labelEn: 'Large Room',   labelEs: 'Cuarto Grande', descEn: 'Full home contents, vehicle parts',       descEs: 'Casa completa, repuestos, negocio grande' },
  { type: 'E', dims: '6 × 6 m',     area: '36 m²',    regularPrice: 432,   price: 360, labelEn: 'Warehouse',    labelEs: 'Bodega Grande', descEn: 'Warehouse-size. Serious storage needs.',  descEs: 'Tamaño bodega. Para necesidades serias.' },
];
---

<!DOCTYPE html>
<html lang="en" class="lang-en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/logo.png" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/logo.png" />

  <title>AA Self Storage MiniBodegas | Self Storage Costa Rica · From $50/mo</title>
  <meta name="description" content="Secure self storage in La Uruca, San José, Costa Rica. Expat-friendly, English-speaking staff. Units from $50/month USD. CCTV. No contract. Mini bodegas." />

  <!-- hreflang -->
  <link rel="alternate" hreflang="en"        href="https://aastorage.web.app/" />
  <link rel="alternate" hreflang="es-CR"     href="https://aastorage.web.app/" />
  <link rel="alternate" hreflang="x-default" href="https://aastorage.web.app/" />

  <!-- OG -->
  <meta property="og:type"        content="website" />
