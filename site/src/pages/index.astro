<!-- GSAP via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>

<script is:inline>
  // ── Language toggle ─────────────────────────────────────────
  function setLang(lang) {
    const html = document.documentElement;
    html.className = 'lang-' + lang;
    html.lang = lang === 'es' ? 'es-CR' : 'en';
    document.getElementById('btn-en').classList.toggle('active', lang === 'en');
    document.getElementById('btn-es').classList.toggle('active', lang === 'es');
    try { localStorage.setItem('lang', lang); } catch(e){}
  }

  (function initLang() {
    try {
      const saved = localStorage.getItem('lang');
      if (saved === 'es') setLang('es');
      else setLang('en');
    } catch(e) { setLang('en'); }
  })();

  // ── Photo Carousel ───────────────────────────────────────────
  (function initPhotoCarousel() {
    var slides  = document.querySelectorAll('.pc-slide');
    var dots    = document.querySelectorAll('.pc-dot');
    var current = 0;
    var total   = slides.length;
    var timer;

    // Slide 0 (expats couple) 6s; unit photos 3s each
    var TIMINGS = [6000, 3000, 3000, 3000, 3000, 3000];

    function getLang() {
      return document.documentElement.className === 'lang-es' ? 'es' : 'en';
    }

    function getBgUrl(bg) {
      var lang = getLang();
      return (lang === 'es' ? bg.dataset.bgEs : bg.dataset.bgEn) || bg.dataset.bg;
    }

    function loadBg(slide) {
      var bg = slide.querySelector('.pc-bg');
      if (!bg) return;
      var url = getBgUrl(bg);
      if (url && !bg.dataset.loaded) {
        bg.style.backgroundImage = 'url(' + url + ')';
        if (!bg.dataset.bgEn) bg.dataset.loaded = '1';
      }
    }

    // Skip KB on solid/tagline slides (no .pc-bg or no background-image)
    function restartKB(slide) {
      var bg = slide.querySelector('.pc-bg');
      if (!bg || !bg.style.backgroundImage) return;
      bg.classList.remove('kb');
      void bg.offsetWidth;
      bg.classList.add('kb');
    }

    function goTo(next) {
      if (next === current) return;
      var out = slides[current];
      var ins = slides[next];
      loadBg(ins);
      if (typeof gsap !== 'undefined') {
        gsap.to(out, { opacity: 0, duration: 0.5, ease: 'power2.inOut',
          onComplete: function() { out.classList.remove('active'); } });
        gsap.fromTo(ins, { opacity: 0 }, { opacity: 1, duration: 0.5, ease: 'power2.inOut',
          onStart: function() { ins.classList.add('active'); restartKB(ins); } });
      } else {
        out.classList.remove('active');
        ins.classList.add('active');
        restartKB(ins);
      }
      dots[current].classList.remove('active');
      dots[next].classList.add('active');
      current = next;
    }

    function nextSlide() { goTo((current + 1) % total); }
    function prevSlide() { goTo((current - 1 + total) % total); }

    // Variable per-slide timer using setTimeout
    function scheduleNext() {
      clearTimeout(timer);
      var delay = TIMINGS[current] !== undefined ? TIMINGS[current] : 3000;
      timer = setTimeout(function() {
        nextSlide();
        scheduleNext();
      }, delay);
    }

    loadBg(slides[0]);
    restartKB(slides[0]);

    var btnNext = document.getElementById('pc-next');
    var btnPrev = document.getElementById('pc-prev');
    if (btnNext) btnNext.addEventListener('click', function() { nextSlide(); scheduleNext(); });
    if (btnPrev) btnPrev.addEventListener('click', function() { prevSlide(); scheduleNext(); });

    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() { goTo(i); scheduleNext(); });
    });

    var track = document.getElementById('photo-carousel');
    if (track) {
      var tx = 0;
      track.addEventListener('touchstart', function(e) { tx = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - tx;
        if (Math.abs(dx) > 50) {
          if (dx < 0) nextSlide(); else prevSlide();
          scheduleNext();
        }
      }, { passive: true });
    }

    // Language switch: reload lang-aware bg (slide 0 only)
    document.addEventListener('click', function(e) {
      if (e.target.id !== 'btn-en' && e.target.id !== 'btn-es') return;
      setTimeout(function() {
        slides.forEach(function(slide) {
          var bg = slide.querySelector('.pc-bg');
          if (!bg || !bg.dataset.bgEn) return;
          var url = getBgUrl(bg);
          if (url) bg.style.backgroundImage = 'url(' + url + ')';
        });
      }, 50);
    });

    scheduleNext();
  })();
</script>


<script is:inline>
(function initLeadGen() {
  var FORMSPREE = 'https://formspree.io/f/xkopejwp';

  /* ── Helpers ─────────────────────────────────── */
  function openOverlay(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.add('open');
    document.body.style.overflow = 'hidden';
    var bar = document.getElementById('sticky-bar');
    if (bar) bar.classList.add('hidden');
  }

  function closeOverlay(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('open');
    document.body.style.overflow = '';
    // Re-show sticky bar only if no other popup is open
    if (!document.querySelector('.lg-overlay.open')) {
      var bar = document.getElementById('sticky-bar');
      if (bar) bar.classList.remove('hidden');
    }
  }

  function postForm(form, callback) {
    var btn = form.querySelector('.lg-btn');
    if (btn) btn.disabled = true;
    var data = new FormData(form);
    fetch(FORMSPREE, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' }
    })
    .then(function(r) { callback(r.ok); })
    .catch(function() { callback(false); })
    .finally(function() { if (btn) btn.disabled = false; });
  }

  function showThanks(wrapId, thanksId) {
    var w = document.getElementById(wrapId);
    var t = document.getElementById(thanksId);
    if (w) w.style.display = 'none';
    if (t) t.style.display = 'block';
  }

  /* ── Escape key ──────────────────────────────── */
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    if (document.getElementById('lead-popup').classList.contains('open')) closeLead();
    if (document.getElementById('exit-popup').classList.contains('open')) closeOverlay('exit-popup');
  });

  /* ── Free Guide Popup ────────────────────────── */
  var exitReady = false;

  function closeLead() {
    closeOverlay('lead-popup');
    try { sessionStorage.setItem('aa_popup_seen', '1'); } catch(e) {}
    exitReady = true;
  }

  var lpClose = document.getElementById('lp-close');
  if (lpClose) lpClose.addEventListener('click', closeLead);

  var leadPopup = document.getElementById('lead-popup');
  if (leadPopup) {
    leadPopup.addEventListener('click', function(e) {
      if (e.target === leadPopup) closeLead();
    });
  }

  /* ── Name validation helpers ─────────────────── */
  var VOWELS = /[aeiouáéíóúü]/i;
  var CONSONANTS = /[bcdfghjklmnñpqrstvwxyz]/i;
  var LETTERS_ONLY = /^[a-záéíóúüñA-ZÁÉÍÓÚÜÑ\s\-']+$/;

  function validateName(val) {
    var v = val.trim();
    if (!v) return 'Required / Requerido';
    if (v.length < 2) return 'Too short / Muy corto';
    if (!LETTERS_ONLY.test(v)) return 'Letters only / Solo letras';
    if (/(.)\1\1/.test(v)) return 'Looks like gibberish / Parece inválido';
    if (!VOWELS.test(v)) return 'Must contain a vowel / Debe tener una vocal';
    if (!CONSONANTS.test(v)) return 'Looks like gibberish / Parece inválido';
    return null;
  }

  function showFieldError(inputEl, errorEl, msg) {
    if (msg) {
      inputEl.classList.add('invalid');
      errorEl.textContent = msg;
      errorEl.classList.add('visible');
      return false;
    } else {
      inputEl.classList.remove('invalid');
      errorEl.textContent = '';
      errorEl.classList.remove('visible');
      return true;
    }
  }

  function validateLeadForm(form) {
    var ok = true;
    var nameFields = ['first_name', 'last_name_1', 'last_name_2'];
    nameFields.forEach(function(name) {
      var input = form.querySelector('[name="' + name + '"]');
      var errEl = document.getElementById('err-' + name);
      if (!showFieldError(input, errEl, validateName(input.value))) ok = false;
    });
    var emailInput = form.querySelector('[name="email"]');
    var emailErr = document.getElementById('err-email');
    var emailVal = emailInput.value.trim().toLowerCase();
    var emailMsg = null;
    if (!emailVal) {
      emailMsg = 'Required / Requerido';
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(emailVal)) {
      emailMsg = 'Invalid email / Correo inválido';
    } else {
      var emailLocal = emailVal.split('@')[0];
      var emailDomain = emailVal.split('@')[1];
      var fakeDomains = ['test.com','example.com','example.org','example.net',
        'fake.com','dummy.com','mailinator.com','tempmail.com','throwaway.email',
        'guerrillamail.com','yopmail.com','trashmail.com','sharklasers.com',
        'maildrop.cc','dispostable.com','getairmail.com','spam4.me'];
      var fakeLocals = ['test','fake','dummy','asdf','qwerty','admin','user',
        'nobody','noreply','no-reply','donotreply','nothing','aaa','bbb','ccc',
        'abc','xyz','123','1234'];
      if (fakeDomains.indexOf(emailDomain) !== -1) {
        emailMsg = 'Please use a real email / Use un correo real';
      } else if (fakeLocals.indexOf(emailLocal) !== -1) {
        emailMsg = 'Please use a real email / Use un correo real';
      } else if (/^(.)\1+$/.test(emailLocal)) {
        emailMsg = 'Please use a real email / Use un correo real';
      }
    }
    if (!showFieldError(emailInput, emailErr, emailMsg)) ok = false;
    var consent = form.querySelector('[name="consent"]');
    var consentErr = document.getElementById('err-consent');
    if (!consent.checked) {
      consentErr.textContent = 'Please agree to continue / Por favor acepta para continuar';
      consentErr.classList.add('visible');
      ok = false;
    } else {
      consentErr.textContent = '';
      consentErr.classList.remove('visible');
    }
    return ok;
  }

  var lpForm = document.getElementById('lp-form');
  if (lpForm) {
    lpForm.addEventListener('submit', function(e) {
      e.preventDefault();
      if (!validateLeadForm(lpForm)) return;
      var btn = lpForm.querySelector('.lg-btn');
      if (btn) btn.disabled = true;
      fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          first_name:  lpForm.querySelector('[name="first_name"]').value.trim(),
          last_name_1: lpForm.querySelector('[name="last_name_1"]').value.trim(),
          last_name_2: lpForm.querySelector('[name="last_name_2"]').value.trim(),
          email:       lpForm.querySelector('[name="email"]').value.trim()
        })
      })
      .finally(function() {
        if (btn) btn.disabled = false;
        // Always show success — download button is fallback if email fails
        showThanks('lp-form-wrap', 'lp-thanks');
      });
    });
  }

  // Trigger after 25 seconds (allow carousel to cycle first)
  try {
    if (!sessionStorage.getItem('aa_popup_seen')) {
      setTimeout(function() { openOverlay('lead-popup'); }, 25000);
    } else {
      exitReady = true;
    }
  } catch(e) {
    setTimeout(function() { openOverlay('lead-popup'); }, 25000);
  }

  /* ── Exit Intent Popup ───────────────────────── */
  var exitFired = false;

  document.addEventListener('mouseleave', function(e) {
    if (e.clientY >= 20) return;
    if (!exitReady || exitFired) return;
    exitFired = true;
    openOverlay('exit-popup');
  });

  var epClose = document.getElementById('ep-close');
  if (epClose) epClose.addEventListener('click', function() { closeOverlay('exit-popup'); });

  var exitPopup = document.getElementById('exit-popup');
  if (exitPopup) {
    exitPopup.addEventListener('click', function(e) {
      if (e.target === exitPopup) closeOverlay('exit-popup');
    });
  }

  var epForm = document.getElementById('ep-form');
  if (epForm) {
    epForm.addEventListener('submit', function(e) {
      e.preventDefault();
      postForm(epForm, function(ok) {
        if (ok) showThanks('ep-form-wrap', 'ep-thanks');
      });
    });
  }

  /* ── Sticky Bar — Free Guide button ─────────── */
  var sbGuide = document.getElementById('sb-guide-btn');
  if (sbGuide) {
    sbGuide.addEventListener('click', function() {
      openOverlay('lead-popup');
    });
  }

  /* ── Hero Free Guide button ──────────────────── */
  var heroGuide = document.getElementById('hero-guide-btn');
  if (heroGuide) {
    heroGuide.addEventListener('click', function() {
      openOverlay('lead-popup');
    });
  }

  /* ── Unit Card Alert Forms ───────────────────── */
  document.querySelectorAll('.alert-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var form = btn.nextElementSibling;
      if (form) form.classList.toggle('open');
    });
  });

  document.querySelectorAll('.alert-unit-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      postForm(form, function(ok) {
        if (!ok) return;
        var wrap = form.closest('.alert-form');
        if (!wrap) return;
        form.style.display = 'none';
        var thanks = wrap.querySelector('.alert-thanks');
        if (thanks) thanks.style.display = 'block';
      });
    });
  });

})();
</script>

